# Django секретный ключ (для продакшена используйте сильный ключ)
# Сгенерируйте с помощью: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production

# Режим отладки (False для продакшена)
DEBUG=True

# Разрешённые хосты
ALLOWED_HOSTS=localhost,127.0.0.1

# Использовать SQLite вместо PostgreSQL (для локальной разработки)
USE_SQLITE=1

# Настройки базы данных PostgreSQL (если не используется SQLite)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_booking

# CORS (разрешить все источники только в разработке)
CORS_ALLOW_ALL_ORIGINS=True
